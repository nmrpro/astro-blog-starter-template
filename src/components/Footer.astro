---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-shell">
		<div>
			<p class="kicker">Pnicta LLC</p>
			<h2>Structured companies. Deliberate work.</h2>
			<p>
				Pnicta is the parent company of Antimony Labs and Antimony Home.
			</p>
		</div>

		<div class="grid">
			<div>
				<h3>Companies</h3>
				<ul>
					<li>Antimony Labs</li>
					<li>Antimony Home</li>
				</ul>
			</div>
			<div>
				<h3>Principles</h3>
				<ul>
					<li>Verification before assumption</li>
					<li>Systems over improvisation</li>
					<li>Competence without spectacle</li>
				</ul>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		© {today.getFullYear()} Pnicta LLC
	</div>
</footer>

<style>
.site-footer {
	margin-top:4rem;
	padding:2rem;
	background:#0b1921;
	color:white;
}
.footer-shell {
	max-width:1100px;
	margin:auto;
	display:grid;
	grid-template-columns:1fr 1fr;
	gap:2rem;
}
.footer-bottom {
	text-align:center;
	margin-top:2rem;
	opacity:.6;
}
</style>
