---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="header-shell">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
			<svg class="brand-mark" viewBox="0 0 160 160">
				<defs>
					<linearGradient id="headerPnictaGlow" x1="0%" y1="0%" x2="100%" y2="100%">
						<stop offset="0%" stop-color="#13a39d" />
						<stop offset="100%" stop-color="#0f6d69" />
					</linearGradient>
				</defs>
				<circle cx="80" cy="80" r="60"
					fill="none"
					stroke="rgba(18,33,42,0.16)"
					stroke-width="10"
					stroke-linecap="square"
					stroke-dasharray="300 95"
					transform="rotate(-28 80 80)" />
				<path d="M96 42c-18 0-31 10-31 23 0 13 10 18 24 22 15 4 24 8 24 18 0 12-12 21-30 21-14 0-28-5-39-14"
					fill="none"
					stroke="url(#headerPnictaGlow)"
					stroke-width="10"
					stroke-linecap="round" />
			</svg>

			<div class="brand-copy">
				<span class="brand-name">{SITE_TITLE}</span>
				<span class="brand-tag">Parent company of the Antimony businesses</span>
			</div>
		</a>

		<nav class="nav">
			<div class="nav-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
		</nav>
	</div>
</header>

<style>
.site-header {
	position: sticky;
	top: 0;
	backdrop-filter: blur(18px);
	background: rgba(243,246,248,0.7);
	border-bottom: 1px solid rgba(var(--black),0.08);
}
.header-shell {
	width: min(1180px,100%);
	margin: 0 auto;
	display:flex;
	justify-content:space-between;
	align-items:center;
}
.brand {
	display:flex;
	gap:.8rem;
	text-decoration:none;
	color:inherit;
}
.brand-mark { width:48px; }
.brand-name { font-weight:800; }
.nav-links {
	display:flex;
	gap:.3rem;
	background:white;
	border-radius:999px;
	padding:.3rem;
}
</style>
